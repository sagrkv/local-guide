# Database
DATABASE_URL="postgresql://user:password@localhost:5432/boko"

# Clerk Authentication
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""

# JWT (Legacy - kept for migration, remove after Clerk migration complete)
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRES_IN="7d"

# Redis (for BullMQ)
REDIS_URL="redis://localhost:6379"

# Server
PORT=3001
NODE_ENV="development"
LOG_LEVEL="info"

# Admin URL Prefix (Security through obscurity)
# SECURITY: Change this prefix periodically and keep it secret
# This must match NEXT_PUBLIC_ADMIN_PREFIX in the frontend
ADMIN_URL_PREFIX="nucleus-admin-x7k9m2"

# CORS
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# Frontend
FRONTEND_URL="http://localhost:3000"

# Scraping
SCRAPE_DELAY_MS=3000
SCRAPE_MAX_REQUESTS_PER_MINUTE=10

# Perplexity AI (optional - for AI-powered business enrichment)
PERPLEXITY_API_KEY=""

# Google Places API (optional - for Google Places discovery)
# Get your API key from: https://console.cloud.google.com/apis/credentials
# Enable "Places API (New)" in your Google Cloud project
# Pricing: $0.032 per Text Search request (100 QPM limit)
# Required for rectangular bounds search (locationRestriction)
GOOGLE_PLACES_API_KEY=""
