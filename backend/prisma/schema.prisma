generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Enums

enum UserRole {
  ADMIN
  CURATOR
  VIEWER
}

enum CityStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum POIStatus {
  AI_SUGGESTED
  UNDER_REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
}

enum POIPriority {
  MUST_VISIT
  RECOMMENDED
  HIDDEN_GEM
  OPTIONAL
}

enum BestSeason {
  SPRING
  SUMMER
  AUTUMN
  WINTER
  MONSOON
  ALL_YEAR
}

enum TimeOfDay {
  EARLY_MORNING
  MORNING
  AFTERNOON
  EVENING
  NIGHT
  ANY_TIME
}

enum TransportMode {
  WALK
  BICYCLE
  AUTO_RICKSHAW
  TAXI
  BUS
  METRO
  TRAIN
  BOAT
  CABLE_CAR
  NONE
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum DiscoveryJobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
}

// Models

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  imageUrl  String?
  password  String?
  role      UserRole @default(VIEWER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  curatedPOIs        POI[]          @relation("CuratedBy")
  createdItineraries Itinerary[]
  createdCollections Collection[]
  uploadedMedia      Media[]
  discoveryJobs      DiscoveryJob[]
  auditLogs          AuditLog[]

  @@map("users")
}

model City {
  id          String     @id @default(cuid())
  name        String
  slug        String     @unique
  tagline     String?
  description String?    @db.Text
  country     String     @default("India")
  state       String?

  heroImageUrl String?
  ogImageUrl   String?

  centerLat    Float
  centerLng    Float
  defaultZoom  Int        @default(13)
  boundsNorthLat Float?
  boundsSouthLat Float?
  boundsEastLng  Float?
  boundsWestLng  Float?

  timezone  String     @default("Asia/Kolkata")
  currency  String     @default("INR")
  language  String     @default("en")
  status    CityStatus @default(DRAFT)
  sortOrder Int        @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  theme         CityTheme?
  pois          POI[]
  categories    Category[]
  itineraries   Itinerary[]
  collections   Collection[]
  media         Media[]
  discoveryJobs DiscoveryJob[]

  @@index([status])
  @@index([slug])
  @@index([sortOrder])
  @@map("cities")
}

model CityTheme {
  id     String @id @default(cuid())
  cityId String @unique

  themePresetId   String @default("default")

  colorPrimary    String @default("#1E3A5F")
  colorSecondary  String @default("#F5E6D3")
  colorAccent     String @default("#D4A574")
  colorBackground String @default("#FAFAF8")
  colorText       String @default("#1A1A1A")

  displayFontUrl    String?
  displayFontFamily String @default("'Playfair Display', serif")
  bodyFontUrl       String?
  bodyFontFamily    String @default("'Inter', sans-serif")

  logoUrl              String?
  emblemUrl            String?
  backgroundPatternUrl String?

  mapStyleJson Json?
  mapTileUrl   String?
  iconPack     String @default("default")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@map("city_themes")
}

model POI {
  id     String @id @default(cuid())
  cityId String
  slug   String

  name             String
  shortDescription String?
  longDescription  String?    @db.Text
  latitude         Float
  longitude        Float
  googlePlaceId    String?    @unique

  categoryId  String
  subcategory String?

  estimatedTimeToSpend String?
  bestTimeToVisit      TimeOfDay  @default(ANY_TIME)
  bestSeason           BestSeason @default(ALL_YEAR)
  entryFee             String?
  openingHours         Json?
  dressCode            String?

  phone           String?
  website         String?
  instagram       String?
  address         String?
  directionsNote  String?    @db.Text
  nearestLandmark String?

  parkingAvailable     Boolean @default(false)
  wheelchairAccessible Boolean @default(false)
  petFriendly          Boolean @default(false)
  wifiAvailable        Boolean @default(false)
  familyFriendly       Boolean @default(true)
  budgetFriendly       Boolean @default(false)

  localTip    String? @db.Text
  warningNote String? @db.Text

  status          POIStatus   @default(AI_SUGGESTED)
  curatedById     String?
  aiSuggestedAt   DateTime?
  humanApprovedAt DateTime?
  verifiedAt      DateTime?
  qualityScore    Int?
  rejectionReason String?

  priority      POIPriority @default(RECOMMENDED)
  iconOverride  String?
  colorOverride String?
  sortOrder     Int         @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city            City             @relation(fields: [cityId], references: [id], onDelete: Cascade)
  category        Category         @relation(fields: [categoryId], references: [id])
  curatedBy       User?            @relation("CuratedBy", fields: [curatedById], references: [id])
  photos          POIPhoto[]
  tags            TagsOnPOIs[]
  itineraryStops  ItineraryStop[]
  collectionItems CollectionItem[]

  @@unique([cityId, slug])
  @@index([cityId, status])
  @@index([cityId, categoryId])
  @@index([cityId, priority])
  @@index([status])
  @@index([categoryId])
  @@index([latitude, longitude])
  @@index([qualityScore])
  @@index([sortOrder])
  @@map("pois")
}

model POIPhoto {
  id        String  @id @default(cuid())
  poiId     String
  url       String
  caption   String?
  source    String?
  isPrimary Boolean @default(false)
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  poi POI @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@index([poiId, sortOrder])
  @@index([poiId, isPrimary])
  @@map("poi_photos")
}

model Category {
  id       String  @id @default(cuid())
  name     String
  slug     String
  icon     String?
  color    String  @default("#6366f1")
  emoji    String?

  isGlobal  Boolean @default(true)
  cityId    String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city City? @relation(fields: [cityId], references: [id], onDelete: Cascade)
  pois POI[]

  @@unique([slug, cityId])
  @@index([isGlobal])
  @@index([cityId])
  @@index([sortOrder])
  @@map("categories")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  slug  String @unique
  color String @default("#6366f1")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pois TagsOnPOIs[]

  @@map("tags")
}

model TagsOnPOIs {
  poiId String
  tagId String

  poi POI @relation(fields: [poiId], references: [id], onDelete: Cascade)
  tag Tag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@id([poiId, tagId])
  @@map("tags_on_pois")
}

model Itinerary {
  id          String        @id @default(cuid())
  cityId      String
  title       String
  slug        String
  description String?       @db.Text
  duration    String
  coverImageUrl String?
  difficulty    String?
  estimatedBudget String?
  status      ContentStatus @default(DRAFT)
  sortOrder   Int           @default(0)

  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city      City            @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdBy User            @relation(fields: [createdById], references: [id])
  stops     ItineraryStop[]

  @@unique([cityId, slug])
  @@index([cityId, status])
  @@index([cityId, sortOrder])
  @@map("itineraries")
}

model ItineraryStop {
  id            String        @id @default(cuid())
  itineraryId   String
  poiId         String
  order         Int
  timeOfDay     TimeOfDay     @default(ANY_TIME)
  duration      String?
  note          String?       @db.Text
  transportToNext TransportMode @default(NONE)
  transportNote   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  poi       POI       @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([itineraryId, order])
  @@index([itineraryId])
  @@index([poiId])
  @@map("itinerary_stops")
}

model Collection {
  id            String        @id @default(cuid())
  cityId        String
  title         String
  slug          String
  description   String?       @db.Text
  coverImageUrl String?
  status        ContentStatus @default(DRAFT)
  sortOrder     Int           @default(0)

  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city      City             @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdBy User             @relation(fields: [createdById], references: [id])
  items     CollectionItem[]

  @@unique([cityId, slug])
  @@index([cityId, status])
  @@index([cityId, sortOrder])
  @@map("collections")
}

model CollectionItem {
  id           String  @id @default(cuid())
  collectionId String
  poiId        String
  order        Int
  note         String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  collection Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  poi        POI        @relation(fields: [poiId], references: [id], onDelete: Cascade)

  @@unique([collectionId, poiId])
  @@unique([collectionId, order])
  @@index([collectionId])
  @@index([poiId])
  @@map("collection_items")
}

model Media {
  id        String    @id @default(cuid())
  url       String
  filename  String
  mimeType  String
  sizeBytes Int
  width     Int?
  height    Int?
  alt       String?
  type      MediaType @default(IMAGE)

  cityId       String?
  uploadedById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city       City? @relation(fields: [cityId], references: [id], onDelete: SetNull)
  uploadedBy User  @relation(fields: [uploadedById], references: [id])

  @@index([cityId])
  @@index([uploadedById])
  @@index([type])
  @@map("media")
}

model DiscoveryJob {
  id     String @id @default(cuid())
  cityId String

  categorySlug String?
  searchQuery  String?
  source       String  @default("google_places")

  status DiscoveryJobStatus @default(PENDING)

  candidatesFound   Int @default(0)
  approved          Int @default(0)
  rejected          Int @default(0)
  duplicatesSkipped Int @default(0)

  errorMessage String? @db.Text
  errorStack   String? @db.Text

  startedAt   DateTime?
  completedAt DateTime?

  createdById String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city      City @relation(fields: [cityId], references: [id], onDelete: Cascade)
  createdBy User @relation(fields: [createdById], references: [id])

  @@index([cityId])
  @@index([status])
  @@index([createdById])
  @@index([createdAt])
  @@map("discovery_jobs")
}

model AuditLog {
  id           String   @id @default(cuid())
  timestamp    DateTime @default(now())
  userId       String?
  action       String
  resource     String
  resourceId   String?
  details      Json?
  ipAddress    String?
  userAgent    String?
  success      Boolean  @default(true)
  errorMessage String?

  user User? @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([timestamp])
  @@index([resource])
  @@map("audit_logs")
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}
